{
  "name": "voltra",
  "displayName": "Voltra (.vol)",
  "description": "Syntax highlighting and a file icon for Voltra .vol reducer files.",
  "version": "0.1.0",
  "publisher": "voltra",
  "engines": { "vscode": "^1.70.0" },
  "categories": ["Programming Languages"],
  "contributes": {
    "languages": [
      {
        "id": "voltra",
        "aliases": ["Voltra", "vol"],
        "extensions": [".vol"],
        "configuration": "./language-configuration.json",
        "icon": { "light": "./icons/voltra.svg", "dark": "./icons/voltra.svg" }
      }
    ],
    "grammars": [
      {
        "language": "voltra",
        "scopeName": "source.voltra",
        "path": "./syntaxes/voltra.tmLanguage.json"
      }
    ]
  }
}
