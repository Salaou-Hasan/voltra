{
  "name": "@neondb/client",
  "version": "0.1.0",
  "description": "TypeScript/JavaScript client SDK for NeonDB — self-hosted real-time game backend",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "npm run build && node --test dist/tests/*.test.js"
  },
  "keywords": ["neondb", "websocket", "realtime", "game-backend", "messagepack"],
  "license": "MIT",
  "dependencies": {
    "@msgpack/msgpack": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.0.0",
    "typescript": "^5.0.0",
    "ws": "^8.0.0"
  },
  "peerDependencies": {
    "ws": "^8.0.0"
  },
  "peerDependenciesMeta": {
    "ws": {
      "optional": true
    }
  }
}
